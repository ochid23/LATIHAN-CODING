#include <iostream>
using namespace std;

int hitungluas(int panjang, int lebar){
	int hasil = panjang * lebar;
	return hasil;
}

int main(){
	cout<<"=== PROGRAM HITUNG LUAS PERSEGI PANJANG ==="<<endl;
	
	int luas_ruangan = hitungluas(5,4);
	cout<<"Luas ruangan 5x4 : "<<luas_ruangan<<" m2"<<endl;
	
	int luas_lapangan = hitungluas(20,10);
	cout<<"hitung lapangan 20x10 : "<<luas_lapangan <<" m2"<<endl;
	
	return 0;
}
